# AI Configuration
# Set to 'openai' for production or 'mock' for development/testing
AI_VENDOR=mock
# Required when AI_VENDOR=openai
OPENAI_API_KEY=your-openai-api-key-here
# OpenAI model to use (e.g., gpt-4o-mini, gpt-4, gpt-3.5-turbo)
AI_MODEL=gpt-4o-mini
# Legacy setting for mock responses
MOCK_MODE=true

# Persistence Configuration  
# Set to 'true' to persist data via APIs, 'false' for mock mode
NEXT_PUBLIC_PERSIST_TO_API=false

# App Configuration  
UPLOAD_MAX_MB=5
MAX_TOKENS=512

# Development
NODE_ENV=development

# When running in development, set NEXT_PUBLIC_SHOW_DEBUG=true to enable the on-page debug panel
# Default is 'false' (do not show). Only set this in trusted dev environments.
NEXT_PUBLIC_SHOW_DEBUG=false

# Database (SQLite local default)
DATABASE_URL="file:./dev.db"
# Optionally override provider (postgresql for prod)
# PRISMA_PROVIDER=postgresql
# Example Postgres URL:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
